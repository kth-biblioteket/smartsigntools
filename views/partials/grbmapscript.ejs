<script defer>
/**
 * KONFIGURATION OCH STATUS-MAPPNING
 */
const STATUS_CONFIG = {
    'free':          { color: '#0DE47E', cssClass: 'white' },
    'tentative':     { color: '#dfa539', cssClass: 'yellow' },
    'tobeconfirmed': { color: '#dfa539', cssClass: 'orange' },
    'confirmed':     { color: '#e24646', cssClass: 'red' },
    'unavailable':   { color: 'grey',    cssClass: 'grey' }
};

const DEFAULT_COLOR = "#6298D2";
const SVG_NS = "http://www.w3.org/2000/svg";

// Globala inställningar från URL
const urlParams = new URLSearchParams(window.location.search);
const isMapMode = urlParams.get('map') === 'true';
const shouldGetStatus = urlParams.get('bookingstatus') !== 'false';

let mapsLoaded = 0;
const totalMaps = 2; // Vi har två kartor (floor2 och floor3)

$(document).ready(function () {
    if (shouldGetStatus) {
        // Vi anropar INTE getRoomAvailability här direkt.
        // Istället sätter vi bara upp strukturen.
        if (isMapMode) {
            setupMapStructure();
        } else {
            // Om vi inte kör kart-läge (box-vy), kör direkt
            getRoomAvailability();
        }

        // Starta intervallet som vanligt för framtida uppdateringar
        setInterval(getRoomAvailability, 300000);
    } else {
        renderInitialUI([]);
    }
});

/**
 * HÄMTA DATA FRÅN API
 */
function getRoomAvailability() {
    const d = new Date();
    const currentHour = String(d.getHours()).padStart(2, '0');
    const nextHour = String(d.getHours() + 1).padStart(2, '0');
    
    // Uppdatera Header-status
    const statusClass = isMapMode ? "mapstatustext" : "statustext";
    $("#App-content").html(`<div class="${statusClass}">Status ${currentHour}:00 - ${nextHour}:00</div>`);

    const currentTimestamp = Math.floor(Date.now() / 1000);
    // URL baserad på din miljö-variabel
    const apiUrl = `<%= smartsignconfig.bookingystemapiserverurl %>v1/roomsavailability/grouprooms/1/${currentTimestamp}`;

    $.getJSON(apiUrl)
        .done(data => {
            const roomsFiltered = data.filter(room => room.disabled !== 1);
            renderInitialUI(roomsFiltered);
        })
        .fail(err => {
            console.error("Kunde inte hämta rumsstatus:", err);
            // Om API misslyckas, rendera tom vy eller felmeddelande
            renderInitialUI([]);
        });
}

/**
 * RENDERINGSLOGIK
 */
function renderInitialUI(rooms) {
    if (isMapMode) {
        if ($("#floor2Map").length === 0) {
            setupMapStructure();
        }
        updateMapColors(rooms);
    } else {
        generateBoxes(rooms);
    }
}

function setupMapStructure() {
    const html = `
        <div class="floor-plan">
            <div class="map-container">
                <object id="floor2Map" type="image/svg+xml" data="http://localhost:96/smartsigntools/api/v1/floorsvg/65"></object>
            </div>
            <div class="floor-label">Floor 2 (Entrance)</div>
            <div class="booking-footer">
                <div class="qr-container">
                    <img src="https://apps.lib.kth.se/smartsigntools/api/v1/qrcode/general/generate/233" class="qr-code">
                </div>
                <div class="booking-callout">
                    <div class="book-here-text">Book here</div>
                    <svg class="curved-arrow" viewBox="0 0 100 100">
                        <path d="M10,10 Q60,10 90,80" stroke="black" fill="none" stroke-width="5" stroke-linecap="round" />
                        <path d="M70,65 L90,80 L90,55" stroke="black" fill="none" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
            </div>
        </div>
        <div class="floor-plan floor-plan-right">
            <div class="map-container">
                <object id="floor3Map" type="image/svg+xml" data="http://localhost:96/smartsigntools/api/v1/floorsvg/66"></object>
            </div>
            <div class="floor-label">Floor 3</div>
        </div>`;
    
    $("#map-section").html(html);

    // Lyssna på laddning av kartor
    $("#floor2Map, #floor3Map").on("load", function() {
        mapsLoaded++;
        // Kör bara API-anropet när SISTA kartan har laddats klart
        if (mapsLoaded === totalMaps) {
            console.log("Alla kartor laddade. Hämtar data...");
            getRoomAvailability();
        }
    });
}

function updateMapColors(rooms) {
    const floorConfigs = [
        { selector: "#floor2Map", rooms: getFloor2Configs() },
        { selector: "#floor3Map", rooms: getFloor3Configs() }
    ];

    floorConfigs.forEach(floor => {
        const svgObj = $(floor.selector)[0];
        if (!svgObj || !svgObj.contentDocument) return;
        const svgDoc = svgObj.contentDocument;

        floor.rooms.forEach(conf => {
            const el = svgDoc.getElementById(conf.id);
            if (!el) return;

            // Hitta status för rummet
            const roomData = rooms.find(r => r.room_name === conf.number);
            let color = DEFAULT_COLOR;
            
            if (conf.isSpecial) {
                color = "#DEF0FF";
            } else if (roomData) {
                color = STATUS_CONFIG[roomData.status]?.color || DEFAULT_COLOR;
            }

            el.setAttribute("fill", color);
            
            // Rita etikett om den inte redan finns
            if (conf.label && !svgDoc.getElementById("label-" + conf.id)) {
                addRoomLabel(svgDoc, conf);
            }
        });
    });
}

/**
 * SKAPA ETIKETTER I SVG
 */
function addRoomLabel(svgDoc, conf) {
    const path = svgDoc.getElementById(conf.id);
    const targetGroup = svgDoc.getElementById('workspacesFrontGroup');
    if (!path || !targetGroup) return;

    const bbox = path.getBBox();
    const padding = 0.8;
    const offsetX = conf.offX || 0;
    const offsetY = conf.offY || 0;

    // Filter-hantering (endast en gång per SVG)
    if (conf.filter && !svgDoc.getElementById('bg-highlight')) {
        let defs = svgDoc.documentElement.querySelector('defs') || 
                   svgDoc.documentElement.insertBefore(svgDoc.createElementNS(SVG_NS, 'defs'), svgDoc.documentElement.firstChild);
        
        const filter = svgDoc.createElementNS(SVG_NS, 'filter');
        filter.setAttribute('id', 'bg-highlight');
        filter.setAttribute('x', '0'); filter.setAttribute('y', '0');
        filter.setAttribute('width', '1'); filter.setAttribute('height', '1');
        filter.innerHTML = `<feFlood flood-color="#f5f5f5" result="bg" /><feMerge><feMergeNode in="bg" /><feMergeNode in="SourceGraphic" /></feMerge>`;
        defs.appendChild(filter);
    }

    let textX, textY, anchor, baseline;
    switch (conf.pos) {
        case 'right':
            textX = bbox.x + (bbox.width / 2) + offsetX;
            textY = bbox.y - padding + offsetY;
            anchor = "start"; baseline = "central";
            break;
        case 'left':
            textX = bbox.x + (bbox.width / 2) + offsetX;
            textY = bbox.y + bbox.height + padding + offsetY;
            anchor = "end"; baseline = "central";
            break;
        case 'top':
            textX = bbox.x - padding + offsetX;
            textY = bbox.y + (bbox.height / 2) + offsetY;
            anchor = "middle"; baseline = "text-top";
            break;
        case 'bottom':
            textX = bbox.x + bbox.width + padding + offsetX;
            textY = bbox.y + (bbox.height / 2) + offsetY;
            anchor = "middle"; baseline = "hanging";
            break;
        default:
            textX = bbox.x + (bbox.width / 2) + offsetX;
            textY = bbox.y - padding + offsetY;
            anchor = "start"; baseline = "central";
    }

    const newText = svgDoc.createElementNS(SVG_NS, "text");
    newText.setAttribute("id", "label-" + conf.id);
    newText.setAttribute("x", textX);
    newText.setAttribute("y", textY);
    newText.setAttribute("dominant-baseline", baseline);
    newText.setAttribute("text-anchor", anchor);
    newText.setAttribute("transform", `rotate(-90, ${textX}, ${textY})`);
    if (conf.filter) newText.setAttribute("filter", "url(#bg-highlight)");

    Object.assign(newText.style, {
        fontFamily: "Figtree, sans-serif",
        fontWeight: "700",
        fontSize: "3.68px",
        fill: "#000000"
    });

    const tspan = svgDoc.createElementNS(SVG_NS, "tspan");
    tspan.setAttribute("x", textX);
    tspan.setAttribute("y", textY);
    tspan.textContent = conf.label;

    newText.appendChild(tspan);
    targetGroup.appendChild(newText);
}

/**
 * BOX-VY (När map=false)
 */
function generateBoxes(rooms) {
    if (!rooms.length) return;
    
    let html = '<div style="display:flex; flex-wrap:wrap; width:100%;">';
    const itemsPerCol = Math.ceil(rooms.length / 3);
    
    rooms.forEach((room, index) => {
        const cssClass = STATUS_CONFIG[room.status]?.cssClass || 'white';
        // Skapa kolumn-brytning var n:e element om man vill köra float, 
        // men flex-wrap är oftast stabilare i Smartsign
        html += `<div class="${cssClass} Smartsign-item flex-container" style="width:31%; margin:1%;">
                    <div>${room.room_name}</div>
                 </div>`;
    });
    
    html += '</div>';
    $("#grouprooms").html(html);
}

/**
 * RUMS-KONFIGURATIONER
 */
function getFloor2Configs() {
    return [
        { id: "wsF4103", number: "01", label: "x",  pos: 'left', filter: true  },
        { id: "wsF4099", number: "02", label: "x",  pos: 'left', filter: true  },
        { id: "wsF4100", number: "03", label: "x",  pos: 'left', filter: true  },
        { id: "wsF4104", number: "0", label: "0",  pos: 'right', offX: 1 },
        { id: "wsF4168", number: "1", label: "1",  pos: 'right', offX: 1 },
        { id: "wsF4213", number: "2", label: "2",  pos: 'right', offX: 1 },
        { id: "wsF4215", number: "3", label: "3",  pos: 'right', offX: 1 },
        { id: "wsF4216", number: "8", label: "5",  pos: 'left',  offX: 1.5 },
        { id: "wsF4135", number: "7", label: "6",  pos: 'left',  offX: 1.5 },
        { id: "wsF4136", number: "6", label: "7", pos: 'left',  offX: 1.5 },
        { id: "wsF4134", number: "5", label: "8", pos: 'left',  offX: 1.5 },
        { id: "wsF4141", number: "012", label: "x", pos: 'right', offX: -1 },
        { id: "wsF4140", number: "9", label: "9", pos: 'right', offX: -1 },
        { id: "wsF4139", number: "10", label: "10", pos: 'right', offX: -1 },
        { id: "wsF23173", number: "11", label: "11", pos: 'right', offX: -1 },
        { id: "wsF23172", number: "12", label: "12", pos: 'right', offX: -1 },
        { id: "wsF23171", number: "13", label: "13", pos: 'right', offX: -1 },
        { id: "wsF4180", number: "018", label: "x", pos: 'right', filter: true },
        { id: "wsF4181", number: "14", label: "14", pos: 'left', filter: true },
        { id: "wsF4115", number: "15", label: "15", pos: 'top', filter: true, offX: -1 }
    ];
}

function getFloor3Configs() {
    return [
        { id: "wsF4285", number: "16", label: "16",  pos: 'right', offX: 1 },
        { id: "wsF4278", number: "A", label: "A",  pos: 'top', offX: 4  },
        { id: "wsF4277", number: "B", label: "B",  pos: 'top', offX: 4  },
        { id: "wsF4279", number: "C", label: "C",  pos: 'top', offX: 4 },
        // Special-element utan nummer men med färg:
        { id: "wsF4277", isSpecial: true },
        { id: "wsF4278", isSpecial: true },
        { id: "wsF4279", isSpecial: true }
    ];
}
</script>