<% if (smartsignconfig.kiosk) { %>
    <%- include('kioskstyle'); %>
<% } %>

<style>
    :root {
    --free-color: #55a64b;
    --not-confirmed-color: #ecec56;
    --busy-color: #d3554f;
    --unavailable-color: #7d7d7d;
    --closed-color: #6298D2;
    --drop-in-color: #DEF0FF;
    --text-main: #000000;
    }

    .App-content {
        height: 1020px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .App-content.libraryclosed {
        background-color: #000061;
        color: #fff;
    }

    .App-content.libraryclosed .main {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .App-footer {
        margin: 20px;
        font-size: 61px;
    }

    /* Legend Section */
    .legend {
        margin-top: 40px;
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        font-size: 24px;
        font-weight: bold;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .App-content.libraryclosed .legend {
        display: none;
    }

    .box {
        width: 30px;
        height: 30px;
    }

    .green {
        background-color: var(--free-color);
    }

    .yellow {
        background-color: var(--not-confirmed-color);
    }

    .red {
        background-color: var(--busy-color);
    }

    .unavailable {
        background-color: var(--unavailable-color);
    }

    .closed {
        background-color: var(--closed-color);
    }

    .drop-in {
        background-color: var(--drop-in-color);
    }

    @media (max-width: 480px) {
        .map-section {
            flex-direction: column;
        }

        h1 {
            font-size: 32px;
        }
    }

    .container {
        width: 400px;
        height: 200px;
        position: absolute;
        top: 30%;
        left: 50%;
        overflow: hidden;
        text-align: center;
        transform: translate(-50%, -50%);
    }
</style>