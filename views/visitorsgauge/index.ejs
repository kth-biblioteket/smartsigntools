<!doctype html>
<html lang="sv">

<head>
    <%- include('../partials/head'); %>
        <link rel="stylesheet" href="/smartsigntools/css/smartsign.css">
        <style>
            :root {
                --free-color: #55a64b;
                --busy-color: #ecec56;
                --full-color: #d3554f;
                --closed-color: #7d7d7d;
                --text-main: #000000;
            }
        </style>
        <link rel="stylesheet" href="/smartsigntools/visitorsgauge/style.css">
        <% if (smartsignconfig.kiosk) { %>
            <link rel="stylesheet" href="/smartsigntools/visitorsgauge/kioskstyle.css">
            <% } %>
</head>

<body>
    <div class="App">
    <% if (!smartsignconfig.kiosk) { %>
      <div class="App-title App-padding content-top">
        <div class="titleimage">
          <img src="/smartsigntools/images/biblioteket_idag_1000_900.jpg" alt="logo" />
        </div>
        <div class="kthlogo">
          <img src="/smartsigntools/images/kthlogo_vit.svg">
        </div>
        <div class="kthname">KTH Library</div>
        <div class="rubrik">How busy are we right now?</div>
      </div>
      <% } %>
    <div class="main-wrapper">
        <% 
        // En hjälpfunktion för att kolla status baserat på ID
        const isVisible = (id) => {
            const site = smartsignconfig.sites.find(s => s[0] === id);
            return site ? site[5] : false; 
        };
        %>
        <div class="gauge-row large-row">
            <% if (isVisible('gaugeHB')) { %>
            <div class="gauge-unit">
                <div id="gaugeHBheader" class="header-text"></div>
                <div class="gaugecontainer" id="gaugeHB"></div>
            </div>
            <% } %>
        </div>
        <div class="gauge-row small-row spacebetween">
            <% if (isVisible('gaugeSOG')) { %>
            <div class="gauge-unit">
                <div id="gaugeSOGheader" class="header-text"></div>
                <div class="gaugecontainer" id="gaugeSOG"></div>
            </div>
            <% } %>
            <% if (isVisible('gaugeNG')) { %>
            <div class="gauge-unit">
                <div id="gaugeNGheader" class="header-text"></div>
                <div class="gaugecontainer" id="gaugeNG"></div>
            </div>
            <% } %>
            <% if (isVisible('gaugeSG')) { %>
            <div class="gauge-unit">
                <div id="gaugeSGheader" class="header-text"></div>
                <div class="gaugecontainer" id="gaugeSG"></div>
            </div>
            <% } %>
            <% if (isVisible('gaugeANGDOMEN')) { %>
            <div class="gauge-unit">
                <div id="gaugeANGDOMENheader" class="header-text"></div>
                <div class="gaugecontainer" id="gaugeANGDOMEN"></div>
            </div>
            <% } %>
        </div>
        <div class="gauge-row small-row">
            <% if (isVisible('gaugeOM')) { %>
            <div class="gauge-unit">
                <div id="gaugeOMheader" class="header-text"></div>
                <div class="gaugecontainer" id="gaugeOM"></div>
            </div>
            <% } %>
        </div>
    </div>
    <script>
        window.CONFIG = <%- JSON.stringify(smartsignconfig) %>;
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/smartsigntools/visitorsgauge/script.js?ver=3.5"></script>
</body>

</html>