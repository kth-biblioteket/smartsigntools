<!doctype html>
<html lang="en">

<head>
  <%- include('../partials/maphead'); %>
    <link rel="stylesheet" href="/smartsigntools/css/smartsign.css">
    <style>
      :root {
        /*--free-color: <%= smartsignconfig.mapconfig.statusConfig.free.color %>;*/
        --free-color: #55a64b;
        --busy-color: #ecec56;
        --full-color: #d3554f;
        --closed-color: #7d7d7d;
        --text-main: #000000;
      }
    </style>
    <link rel="stylesheet" href="/smartsigntools/visitorsmap/style.css">
    <% if (smartsignconfig.kiosk) { %>
      <link rel="stylesheet" href="/smartsigntools/visitorsmap/kioskstyle.css">
      <% } %>
</head>

<body>
  <div class="App">
    <% if (!smartsignconfig.kiosk) { %>
      <div class="App-title App-padding content-top">
        <div class="titleimage">
          <img src="/smartsigntools/images/biblioteket_idag_1000_900.jpg" alt="logo" />
        </div>
        <div class="kthlogo">
          <img src="/smartsigntools/images/kthlogo_vit.svg">
        </div>
        <div class="kthname">KTH Library</div>
        <div class="rubrik">How busy are we right now?</div>
      </div>
      <% } %>
        <div class="App-content content-padding">
          <div id="map-section" class="map-section">
          </div>
          <div class="App-footer">
            <div class="legend">
              <div class="legend-item">
                <div class="box free"></div> Free
              </div>
              <div class="legend-item">
                <div class="box busy"></div> Busy
              </div>
              <div class="legend-item">
                <div class="box full"></div> Full
              </div>
              <div class="legend-item">
                <div class="box closed"></div> Closed
              </div>
            </div>
          </div>
        </div>
  </div>
  <script>
    window.CONFIG = <%- JSON.stringify(smartsignconfig) %>;
  </script>
  <script src="/smartsigntools/visitorsmap/script.js?ver=3.5"></script>
</body>

</html>